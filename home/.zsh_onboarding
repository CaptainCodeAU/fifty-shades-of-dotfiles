# ~/.zsh_onboarding
# ==============================================================================
#  Unified Onboarding & Dependency Checker
# ==============================================================================
# Cross-platform onboarding script for macOS, Linux, and WSL.
# Checks for essential development tools and offers to install missing ones.
#
# USAGE:
#   - Runs automatically on first shell start
#   - Run manually anytime with: run_onboarding
#
# SUPPORTED PLATFORMS:
#   - macOS (via Homebrew)
#   - Linux: Ubuntu/Debian (apt), Fedora (dnf), Arch (pacman), openSUSE (zypper)
#   - WSL (same as Linux)
#
# Date Created: 16/01/2025
# ==============================================================================

# ------------------------------------------------------------------------------
# UI Helpers (self-contained for portability)
# ------------------------------------------------------------------------------
# These may already be defined in .zshrc, but we define them here too
# to ensure the script works standalone.
if [[ -z "$ok" ]]; then
    autoload -U colors && colors
    ok="$fg[green]"
    warn="$fg[yellow]"
    err="$fg[red]"
    info="$fg[cyan]"
    done="$reset_color"
fi

# ------------------------------------------------------------------------------
# pnpm Version Policy & Cached Latest-Version Check
# ------------------------------------------------------------------------------
# Minimum acceptable pnpm. Below this, install.sh and the onboarding prompt
# offer to upgrade rather than silently accepting the stale version.
# Bumped manually; coordinate with install.sh's PNPM_MIN_VERSION.
export PNPM_MIN_VERSION="${PNPM_MIN_VERSION:-11.2.2}"
# How often to re-check the npm registry for the latest pnpm release.
export PNPM_CHECK_TTL_DAYS="${PNPM_CHECK_TTL_DAYS:-7}"

_pnpm_cache_file() {
    local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/dotfiles"
    [[ -d "$cache_dir" ]] || mkdir -p "$cache_dir" 2>/dev/null
    echo "$cache_dir/pnpm_latest2"
}

# Cache is fresh if its mtime is within PNPM_CHECK_TTL_DAYS AND no version that
# was held by minimumReleaseAge has since crossed the gate (else the cached
# `eligible` is stale and must be recomputed before the TTL would expire).
_pnpm_cache_fresh() {
    local cache_file="$1" max_age now mtime
    [[ -s "$cache_file" ]] || return 1
    max_age=$((PNPM_CHECK_TTL_DAYS * 86400))
    now=$(date +%s)
    if [[ "$OSTYPE" == darwin* ]]; then
        mtime=$(stat -f %m "$cache_file" 2>/dev/null)
    else
        mtime=$(stat -c %Y "$cache_file" 2>/dev/null)
    fi
    [[ -n "$mtime" ]] || return 1
    (( now - mtime < max_age )) || return 1   # past the TTL -> stale

    # Within the TTL, still treat the cache as stale (force a refresh) if a raw
    # version that was gated by minimumReleaseAge has since become eligible.
    # Without this, `eligible` stays behind `raw` and the banner / pnpm_update
    # keep reporting "pending" for a version that is actually installable until
    # the TTL expires. Fields read inline (no helper-in-scope coupling).
    local c_raw c_elig c_at
    c_raw=$(grep -E '^raw=' "$cache_file" 2>/dev/null | head -1 | sed 's/^[^=]*=//')
    c_elig=$(grep -E '^eligible=' "$cache_file" 2>/dev/null | head -1 | sed 's/^[^=]*=//')
    c_at=$(grep -E '^raw_eligible_at=' "$cache_file" 2>/dev/null | head -1 | sed 's/^[^=]*=//')
    if [[ -n "$c_raw" && "$c_raw" != "$c_elig" && "$c_at" == <-> ]] && (( c_at > 0 && now >= c_at )); then
        return 1
    fi
    return 0
}

# Background-refresh cache; never blocks the shell. `&!` is zsh-only —
# disowns and detaches in one shot.
_pnpm_refresh_latest_bg() {
    local cache_file="$1"
    (
        # raw = registry dist-tag latest (cheap; always attempted first).
        local raw eligible min_age now cutoff pkg raw_at raw_eligible_at
        raw=$(curl -fsSL --max-time 5 "https://registry.npmjs.org/pnpm/latest" 2>/dev/null \
            | grep -oE '"version":"[^"]+"' | head -1 | sed 's/.*"\([^"]*\)"/\1/')
        [[ -z "$raw" ]] && return  # network failed; keep any existing cache
        eligible="$raw"
        raw_eligible_at=0
        # eligible = newest stable version old enough to clear minimumReleaseAge,
        # i.e. what `pnpm self-update` will actually accept. Needs the full
        # packument (publish times) + jq; degrade to the dist-tag latest otherwise.
        min_age=$(_pnpm_min_release_age_min)
        if [[ "$min_age" -gt 0 ]] && command -v jq &>/dev/null; then
            pkg=$(curl -fsSL --max-time 8 "https://registry.npmjs.org/pnpm" 2>/dev/null)
            if [[ -n "$pkg" ]]; then
                now=$(date +%s)
                cutoff=$(( now - min_age * 60 ))
                eligible=$(printf '%s' "$pkg" | jq -r --argjson cutoff "$cutoff" '
                    .time | to_entries
                    | map(select(.key | test("^[0-9]+\\.[0-9]+\\.[0-9]+$")))
                    | map(select((.value | sub("\\.[0-9]+Z$";"Z") | fromdateiso8601) <= $cutoff) | .key)
                    | .[]' 2>/dev/null | sort -V | tail -1)
                [[ -z "$eligible" ]] && eligible="$raw"
                if [[ "$raw" != "$eligible" ]]; then
                    raw_at=$(printf '%s' "$pkg" | jq -r --arg v "$raw" \
                        '.time[$v] // empty | sub("\\.[0-9]+Z$";"Z") | fromdateiso8601' 2>/dev/null)
                    [[ -n "$raw_at" ]] && raw_eligible_at=$(( raw_at + min_age * 60 ))
                fi
            fi
        fi
        {
            echo "raw=$raw"
            echo "eligible=$eligible"
            echo "raw_eligible_at=$raw_eligible_at"
        } > "$cache_file"
    ) &!
}

# Echo the configured minimumReleaseAge in minutes (0 if unset or unreadable).
# Reads the same config.yaml pnpm itself reads: the macOS Preferences bridge,
# or the XDG path on Linux/WSL.
_pnpm_min_release_age_min() {
    local cfg v
    if [[ "$OSTYPE" == darwin* && -f "$HOME/Library/Preferences/pnpm/config.yaml" ]]; then
        cfg="$HOME/Library/Preferences/pnpm/config.yaml"
    else
        cfg="${XDG_CONFIG_HOME:-$HOME/.config}/pnpm/config.yaml"
    fi
    [[ -f "$cfg" ]] || { echo 0; return; }
    v=$(grep -oE '^[[:space:]]*minimumReleaseAge[[:space:]]*:[[:space:]]*[0-9]+' "$cfg" 2>/dev/null \
        | grep -oE '[0-9]+' | tail -1)
    echo "${v:-0}"
}

# Read one key=value field from the cache. Tolerates the legacy single-line
# format (a bare version string) by treating it as both raw and eligible.
_pnpm_cache_get() {
    local cache_file="$1" key="$2"
    [[ -f "$cache_file" ]] || return
    if grep -q '=' "$cache_file" 2>/dev/null; then
        grep -E "^${key}=" "$cache_file" 2>/dev/null | head -1 | sed 's/^[^=]*=//'
    elif [[ "$key" == "raw" || "$key" == "eligible" ]]; then
        cat "$cache_file" 2>/dev/null
    fi
}

# Latest INSTALLABLE pnpm version, honoring minimumReleaseAge -- this is what
# `pnpm self-update` will actually accept. Triggers a background refresh when
# the cache is stale. May be empty on the very first call before the refresh
# completes; the next shell sees the populated value.
_pnpm_get_latest() {
    local cache_file
    cache_file=$(_pnpm_cache_file)
    _pnpm_cache_fresh "$cache_file" || _pnpm_refresh_latest_bg "$cache_file"
    _pnpm_cache_get "$cache_file" eligible
}

# Raw registry dist-tag latest, ignoring release age. May be newer than what
# self-update will install (held by the minimumReleaseAge gate). Display only.
_pnpm_get_raw_latest() {
    _pnpm_cache_get "$(_pnpm_cache_file)" raw
}

# Epoch seconds when the raw dist-tag latest clears the release-age gate;
# 0 when it is not gated or the time is unknown.
_pnpm_get_raw_eligible_at() {
    _pnpm_cache_get "$(_pnpm_cache_file)" raw_eligible_at
}

# Compare two semver-ish versions. Echoes -1 (a<b), 0 (==), or 1 (a>b).
_pnpm_vercmp() {
    local a="$1" b="$2"
    [[ "$a" == "$b" ]] && { echo 0; return; }
    local lower
    lower=$(printf '%s\n%s\n' "$a" "$b" | sort -V | head -1)
    if [[ "$lower" == "$a" ]]; then echo -1; else echo 1; fi
}

# ------------------------------------------------------------------------------
# Global Variables
# ------------------------------------------------------------------------------
_PKG_MANAGER_NAME=""
_PKG_MANAGER_CMD=""
_PKG_MANAGER_CHECK=""

# ------------------------------------------------------------------------------
# Package Manager Detection
# ------------------------------------------------------------------------------
_detect_package_manager() {
    _PKG_MANAGER_NAME=""
    _PKG_MANAGER_CMD=""
    _PKG_MANAGER_CHECK=""

    if [[ "$IS_MAC" == "true" ]]; then
        if command -v brew &>/dev/null; then
            _PKG_MANAGER_NAME="Homebrew"
            _PKG_MANAGER_CMD="brew install"
            _PKG_MANAGER_CHECK="brew list"
        else
            _PKG_MANAGER_NAME=""
            _PKG_MANAGER_CMD=""
        fi
    elif command -v apt-get &>/dev/null; then
        _PKG_MANAGER_NAME="apt"
        _PKG_MANAGER_CMD="sudo apt-get install -y"
        _PKG_MANAGER_CHECK="dpkg -l"
    elif command -v dnf &>/dev/null; then
        _PKG_MANAGER_NAME="dnf"
        _PKG_MANAGER_CMD="sudo dnf install -y"
        _PKG_MANAGER_CHECK="dnf list installed"
    elif command -v pacman &>/dev/null; then
        _PKG_MANAGER_NAME="pacman"
        _PKG_MANAGER_CMD="sudo pacman -S --noconfirm"
        _PKG_MANAGER_CHECK="pacman -Q"
    elif command -v zypper &>/dev/null; then
        _PKG_MANAGER_NAME="zypper"
        _PKG_MANAGER_CMD="sudo zypper install -y"
        _PKG_MANAGER_CHECK="zypper se --installed-only"
    else
        echo "${warn}Could not detect package manager. Automatic installation disabled.${done}"
        _PKG_MANAGER_NAME=""
        _PKG_MANAGER_CMD=""
    fi
}

# ------------------------------------------------------------------------------
# Homebrew Bootstrap (macOS only)
# ------------------------------------------------------------------------------
_ensure_homebrew() {
    if [[ "$IS_MAC" != "true" ]]; then
        return 0
    fi

    if command -v brew &>/dev/null; then
        return 0
    fi

    echo "${warn}Homebrew not found.${done}"
    echo "${info}Homebrew is the package manager for macOS and is required to install other tools.${done}"

    if [[ -t 1 ]]; then
        read "REPLY?${info}    Would you like to install Homebrew now? [y/N] ${done}"
        if [[ "$REPLY" =~ ^[Yy]$ ]]; then
            echo "${info}Installing Homebrew...${done}"
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

            if [[ $? -eq 0 ]]; then
                echo "${ok}    Homebrew installed successfully.${done}"
                # Add Homebrew to PATH for this session
                if [[ -d /opt/homebrew ]]; then
                    eval "$(/opt/homebrew/bin/brew shellenv)"
                else
                    eval "$(/usr/local/bin/brew shellenv)"
                fi
                # Re-detect package manager
                _detect_package_manager
            else
                echo "${err}    Homebrew installation failed.${done}"
                return 1
            fi
        else
            echo "${warn}    Skipping Homebrew installation. Some tools cannot be installed automatically.${done}"
            return 1
        fi
    fi
}

# ------------------------------------------------------------------------------
# Generic Command Checker
# ------------------------------------------------------------------------------
# Usage: _ensure_command <command_to_check> <package_name_brew> <package_name_apt>
# If only one package name provided, it's used for all package managers.
_ensure_command() {
    local cmd_to_check="$1"
    local pkg_brew="${2:-$1}"
    local pkg_apt="${3:-$pkg_brew}"
    local pkg_name=""

    # Select package name based on package manager
    if [[ "$_PKG_MANAGER_NAME" == "Homebrew" ]]; then
        pkg_name="$pkg_brew"
    else
        pkg_name="$pkg_apt"
    fi

    # Check if command exists
    if command -v "$cmd_to_check" &>/dev/null; then
        return 0
    fi

    # Command not found — offer to install
    if [[ -n "$_PKG_MANAGER_CMD" && -t 1 ]]; then
        echo "${warn}Tool missing: '$cmd_to_check' not found.${done}"
        read "REPLY?${info}    Install '$pkg_name' using ${_PKG_MANAGER_NAME}? [y/N] ${done}"
        if [[ "$REPLY" =~ ^[Yy]$ ]]; then
            echo "${info}    Installing '$pkg_name'...${done}"
            eval "$_PKG_MANAGER_CMD $pkg_name"
            if [[ $? -eq 0 ]]; then
                echo "${ok}    Successfully installed '$pkg_name'.${done}"
                rehash  # Refresh command cache
            else
                echo "${err}    Installation failed.${done}"
                return 1
            fi
        else
            echo "${warn}    Skipping '$pkg_name'.${done}"
        fi
    else
        echo "${warn}Tool missing: '$cmd_to_check'. Please install '$pkg_name' manually.${done}"
    fi
}

# ------------------------------------------------------------------------------
# NVM (Node Version Manager) — Special Handler
# ------------------------------------------------------------------------------
_ensure_nvm() {
    # NVM is a shell function, not a binary — check for its directory
    if [[ -d "$HOME/.nvm" ]]; then
        return 0
    fi

    if [[ -t 1 ]]; then
        echo "${warn}Tool missing: 'nvm' (Node Version Manager) not found.${done}"
        read "REPLY?${info}    Install nvm from the official source? [y/N] ${done}"
        if [[ "$REPLY" =~ ^[Yy]$ ]]; then
            echo "${info}    Downloading and installing nvm...${done}"
            curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/master/install.sh | bash
            if [[ $? -eq 0 ]]; then
                echo "${ok}    nvm installed successfully.${done}"
                echo "${info}    Note: Restart your shell or run 'source ~/.zshrc' to use nvm.${done}"
            else
                echo "${err}    nvm installation failed.${done}"
            fi
        else
            echo "${warn}    Skipping nvm installation.${done}"
        fi
    fi
}

# ------------------------------------------------------------------------------
# uv (Python Package Manager) — Special Handler
# ------------------------------------------------------------------------------
_ensure_uv() {
    if command -v uv &>/dev/null; then
        return 0
    fi

    if [[ -t 1 ]]; then
        echo "${warn}Tool missing: 'uv' (fast Python package manager) not found.${done}"
        read "REPLY?${info}    Install uv from the official source? [y/N] ${done}"
        if [[ "$REPLY" =~ ^[Yy]$ ]]; then
            echo "${info}    Downloading and installing uv...${done}"
            curl -LsSf https://astral.sh/uv/install.sh | sh
            if [[ $? -eq 0 ]]; then
                echo "${ok}    uv installed successfully.${done}"
                # Add to path for this session
                export PATH="$HOME/.local/bin:$PATH"
                rehash
            else
                echo "${err}    uv installation failed.${done}"
            fi
        else
            echo "${warn}    Skipping uv installation.${done}"
        fi
    fi
}

# ------------------------------------------------------------------------------
# pnpm Below-Minimum Check — Special Handler
# ------------------------------------------------------------------------------
# Prompts to upgrade pnpm if installed version < PNPM_MIN_VERSION.
# Soft (non-blocking) nudges for above-min-but-not-latest live in .zsh_welcome.
# A daily marker file prevents re-prompting on every shell open.
_ensure_pnpm_current() {
    command -v pnpm &>/dev/null || return 0  # missing case handled by install.sh
    [[ -t 1 ]] || return 0

    local current latest cmp_min marker marker_dir
    current=$(pnpm -v 2>/dev/null) || return 0
    cmp_min=$(_pnpm_vercmp "$current" "$PNPM_MIN_VERSION")
    [[ "$cmp_min" != "-1" ]] && return 0  # at or above minimum — silent

    # Below minimum — prompt at most once per 24h
    marker_dir="${XDG_CACHE_HOME:-$HOME/.cache}/dotfiles"
    marker="$marker_dir/pnpm_upgrade_prompted"
    [[ -d "$marker_dir" ]] || mkdir -p "$marker_dir" 2>/dev/null
    if [[ -f "$marker" ]]; then
        local now mtime
        now=$(date +%s)
        if [[ "$OSTYPE" == darwin* ]]; then
            mtime=$(stat -f %m "$marker" 2>/dev/null)
        else
            mtime=$(stat -c %Y "$marker" 2>/dev/null)
        fi
        [[ -n "$mtime" ]] && (( now - mtime < 86400 )) && return 0
    fi

    latest=$(_pnpm_get_latest 2>/dev/null)
    echo "${err}pnpm ${current} is below required minimum ${PNPM_MIN_VERSION}${latest:+ (latest: ${latest})}.${done}"
    # Intel macOS: pnpm is Homebrew-managed (standalone SEA binary segfaults --
    # nodejs/node#62893), so upgrade via brew, not pnpm self-update.
    local upd_label="pnpm self-update"
    [[ "$IS_MAC" == true && "$MAC_ARCH" == "x86_64" ]] && upd_label="brew upgrade pnpm"
    read "REPLY?${info}    Run '${upd_label}' now? [y/N] ${done}"
    : > "$marker"  # mark prompted regardless of answer
    if [[ "$REPLY" =~ ^[Yy]$ ]]; then
        echo "${info}    Updating pnpm...${done}"
        local upd_ok=false
        if [[ "$IS_MAC" == true && "$MAC_ARCH" == "x86_64" ]]; then
            brew upgrade pnpm && upd_ok=true
        else
            pnpm self-update && upd_ok=true
        fi
        if [[ "$upd_ok" == true ]]; then
            echo "${ok}    pnpm updated to $(pnpm -v 2>/dev/null).${done}"
        else
            echo "${err}    pnpm upgrade failed.${done}"
        fi
    else
        echo "${warn}    Skipping pnpm upgrade. Run 'pnpm_update' anytime.${done}"
    fi
}

# ------------------------------------------------------------------------------
# Docker — Guidance Only
# ------------------------------------------------------------------------------
_show_docker_guidance() {
    if command -v docker &>/dev/null; then
        return 0
    fi

    echo "${warn}Tool missing: 'docker' not found.${done}"

    if [[ "$IS_MAC" == "true" ]]; then
        echo "${info}    Docker Desktop for Mac: https://docs.docker.com/desktop/install/mac-install/${done}"
    elif [[ "$IS_WSL" == "true" ]]; then
        echo "${info}    Docker Desktop for Windows (with WSL backend): https://docs.docker.com/desktop/install/windows-install/${done}"
        echo "${info}    Or install Docker Engine in WSL: https://docs.docker.com/engine/install/ubuntu/${done}"
    else
        echo "${info}    Docker Engine installation: https://docs.docker.com/engine/install/${done}"
    fi
}

# ------------------------------------------------------------------------------
# Section Runner — compact display (A+B merged)
# ------------------------------------------------------------------------------
# Usage: _run_section NAME cmd1 brew1 apt1 [cmd2 brew2 apt2 ...]
# When all tools present: prints a single ✓ line with all names.
# When any missing: prints ! line and prompts for each missing tool.
_run_section() {
    local section_name="$1"
    shift
    local -a all_names=()
    local -a miss_cmds=()
    local -a miss_brew=()
    local -a miss_apt=()

    while (( $# >= 3 )); do
        local cmd="$1" pkg_brew="$2" pkg_apt="$3"
        shift 3
        all_names+=("$cmd")
        if ! command -v "$cmd" &>/dev/null; then
            miss_cmds+=("$cmd")
            miss_brew+=("$pkg_brew")
            miss_apt+=("$pkg_apt")
        fi
    done

    local tool_list="${(j: · :)all_names}"
    if (( ${#miss_cmds[@]} == 0 )); then
        printf "  ${ok}✓${done} %-18s %s\n" "$section_name" "$tool_list"
    else
        printf "  ${warn}!${done} %-18s %s\n" "$section_name" "$tool_list"
        local i=1
        while (( i <= ${#miss_cmds[@]} )); do
            _ensure_command "${miss_cmds[$i]}" "${miss_brew[$i]}" "${miss_apt[$i]}"
            (( i++ ))
        done
    fi
}

# ------------------------------------------------------------------------------
# Main Onboarding Function
# ------------------------------------------------------------------------------
run_onboarding() {
    echo
    echo "${info}==============================================================================${done}"
    echo "${info}  Development Environment Onboarding${done}"
    echo "${info}==============================================================================${done}"
    echo

    # Display OS info
    if [[ "$IS_MAC" == "true" ]]; then
        echo "${info}Platform:${done} macOS $(sw_vers -productVersion 2>/dev/null) (${MAC_ARCH:-$(uname -m)})"
    elif [[ "$IS_WSL" == "true" ]]; then
        echo "${info}Platform:${done} WSL ($(lsb_release -ds 2>/dev/null || echo 'Linux'))"
    else
        echo "${info}Platform:${done} $(lsb_release -ds 2>/dev/null || echo 'Linux')"
    fi
    echo

    rehash

    # --- Homebrew (macOS): silent if present, prompts only if missing ---
    if [[ "$IS_MAC" == "true" ]]; then
        _ensure_homebrew
    fi

    # --- Package manager ---
    _detect_package_manager
    if [[ -n "$_PKG_MANAGER_NAME" ]]; then
        printf "  ${ok}✓${done} %-18s %s\n" "Package manager" "$_PKG_MANAGER_NAME"
    else
        printf "  ${warn}!${done} %-18s %s\n" "Package manager" "None detected — install manually"
    fi

    # --- Essential tools ---
    if [[ "$(uname -s)" == "Darwin" ]]; then
        _run_section "Essential" \
            "git"   "git"   "git" \
            "curl"  "curl"  "curl" \
            "unzip" "unzip" "unzip" \
            "trash" "trash" "trash"
    else
        _run_section "Essential" \
            "git"       "git"       "git" \
            "curl"      "curl"      "curl" \
            "unzip"     "unzip"     "unzip" \
            "trash-put" "trash-cli" "trash-cli"
    fi

    # --- UX tools ---
    _run_section "UX tools" \
        "eza"    "eza"    "eza" \
        "fzf"    "fzf"    "fzf" \
        "jq"     "jq"     "jq" \
        "direnv" "direnv" "direnv" \
        "zoxide" "zoxide" "zoxide" \
        "glow"   "glow"   "glow"

    # --- CLI tools ---
    _run_section "CLI tools" \
        "rg"      "ripgrep"  "ripgrep" \
        "nvim"    "neovim"   "neovim" \
        "tree"    "tree"     "tree" \
        "fastfetch" "fastfetch" "fastfetch" \
        "ffmpeg"  "ffmpeg"   "ffmpeg" \
        "yt-dlp"  "yt-dlp"   "yt-dlp" \
        "aria2c"  "aria2"    "aria2" \
        "lazygit" "lazygit"  "lazygit" \
        "lazydocker" "lazydocker" "lazydocker"

    # --- Dev managers (special handlers — not standard binaries) ---
    local nvm_ok=false uv_ok=false pnpm_ok=false
    [[ -d "$HOME/.nvm" ]] && nvm_ok=true
    command -v uv &>/dev/null && uv_ok=true
    # Resolve pnpm even if $PNPM_HOME/bin isn't on PATH yet: onboarding runs in
    # .zshrc section 4, BEFORE section 5 adds it. On Apple Silicon the standalone
    # pnpm lives only at ~/Library/pnpm/bin, so `command -v pnpm` misses it here
    # and would falsely flag Dev managers. Fall back to the known standalone path
    # (Intel macOS uses brew pnpm, already on the default PATH).
    local _pnpm_bin="" _pnpm_cur=""
    if command -v pnpm &>/dev/null; then
        _pnpm_bin=pnpm
    elif [[ -x "$HOME/Library/pnpm/bin/pnpm" ]]; then
        _pnpm_bin="$HOME/Library/pnpm/bin/pnpm"
    elif [[ -x "$HOME/.local/share/pnpm/bin/pnpm" ]]; then
        _pnpm_bin="$HOME/.local/share/pnpm/bin/pnpm"
    fi
    if [[ -n "$_pnpm_bin" ]]; then
        _pnpm_cur=$("$_pnpm_bin" -v 2>/dev/null)
        [[ -n "$_pnpm_cur" && "$(_pnpm_vercmp "$_pnpm_cur" "$PNPM_MIN_VERSION")" != "-1" ]] && pnpm_ok=true
    fi

    if [[ "$nvm_ok" == true && "$uv_ok" == true && "$pnpm_ok" == true ]]; then
        printf "  ${ok}✓${done} %-18s %s\n" "Dev managers" "nvm · uv · pnpm"
    else
        printf "  ${warn}!${done} %-18s %s\n" "Dev managers" "nvm · uv · pnpm"
        [[ "$nvm_ok" == false ]] && _ensure_nvm
        [[ "$uv_ok" == false ]] && _ensure_uv
        [[ "$pnpm_ok" == false ]] && _ensure_pnpm_current
    fi

    # --- Docker ---
    if command -v docker &>/dev/null; then
        if docker ps &>/dev/null 2>&1; then
            printf "  ${ok}✓${done} %-18s %s\n" "Docker" "Running"
        else
            printf "  ${warn}!${done} %-18s %s\n" "Docker" "Not Running"
        fi
    else
        printf "  ${warn}!${done} %-18s\n" "Docker"
        _show_docker_guidance
    fi

    # Pre-create nvim XDG state dirs as the current user to prevent
    # root-ownership issues from prior sudo nvim invocations.
    if command -v nvim &>/dev/null; then
        mkdir -p ~/.local/state/nvim/{shada,swap,undo,backup}
    fi

    echo
    echo "${info}==============================================================================${done}"
    echo "${ok}  Onboarding complete!${done}"
    echo "${info}==============================================================================${done}"
    # echo "${info}Tips:${done}"
