# ── Local override (loaded FIRST so its Host blocks ──────
# match before any base-config Host blocks). All real Host
# definitions — GitHub aliases, trusted LAN remotes, etc. —
# live in ~/.ssh/config.local, which is never stowed and
# never committed (see .gitignore). Keep this base config
# strictly generic so the public repo reveals nothing about
# which accounts or hosts the user operates.
#
# The Include must come before any Host directive: an
# Include placed after a non-matching Host block is parsed
# in "parse only" mode and its directives never apply.
Include ~/.ssh/config.local

# ── Global defaults ──────────────────────────────────────
# Never cache keys in the agent. Every SSH operation will
# prompt for the passphrase. This is the strictest setting.
Host *
    AddKeysToAgent no
    UseKeychain no
    IdentitiesOnly yes
