# ~/.zsh_welcome
# ==============================================================================
#  Unified Welcome & Environment Overview Script
# ==============================================================================
# Cross-platform welcome message for macOS, Linux, and WSL.
#
# VERBOSITY CONTROL (set in ~/.zshrc or ~/.zshrc.private):
#   ZSH_WELCOME          - Environment overview: "full", "minimal", or "none"
#   ZSH_WELCOME_QUICKREF - Quick reference: "full", "minimal", "none"
#   ZSH_WELCOME_DISK_WARN - Disk warning threshold percentage (default: 90)
#
# DEFAULT: "full". Override per-machine via ~/.zshrc.private with
#   export ZSH_WELCOME=minimal   # terse single-line status
#   export ZSH_WELCOME=none      # no overview at all
#
# Date Created: 16/01/2025
# ==============================================================================

# ------------------------------------------------------------------------------
# Verbosity Resolution
# ------------------------------------------------------------------------------
_resolve_welcome_verbosity() {
    # Explicit setting wins; otherwise default to full. SSH/tmux no longer
    # force minimal — those are places you typically want MORE info, not less.
    if [[ -n "$ZSH_WELCOME" ]]; then
        echo "$ZSH_WELCOME"
    else
        echo "full"
    fi
}

# Store resolved verbosity
_WELCOME_VERBOSITY=$(_resolve_welcome_verbosity)
: ${ZSH_WELCOME_QUICKREF:="full"}
: ${ZSH_WELCOME_DISK_WARN:=90}

# ------------------------------------------------------------------------------
# Helper: Get Disk Usage
# ------------------------------------------------------------------------------
_get_disk_usage() {
    local usage_pct free_space

    if [[ "$IS_MAC" == "true" ]]; then
        # macOS: use df on root volume
        usage_pct=$(df -h / | awk 'NR==2 {gsub(/%/,""); print $5}')
        free_space=$(df -h / | awk 'NR==2 {print $4}')
    else
        # Linux/WSL: use df on home directory
        usage_pct=$(df -h ~ | awk 'NR==2 {gsub(/%/,""); print $5}')
        free_space=$(df -h ~ | awk 'NR==2 {print $4}')
    fi

    echo "${usage_pct}:${free_space}"
}

# ------------------------------------------------------------------------------
# Helper: Check GPU Availability (WSL/Linux only)
# ------------------------------------------------------------------------------
_check_gpu() {
    if command -v nvidia-smi &>/dev/null && nvidia-smi &>/dev/null; then
        echo "available"
    else
        echo "none"
    fi
}

# ------------------------------------------------------------------------------
# Full Welcome Display
# ------------------------------------------------------------------------------
_show_welcome_full() {
    echo

    # --- OS Header ---
    if [[ "$IS_MAC" == "true" ]]; then
        echo "${info}🛡️  macOS Environment Overview:${done}"
        echo "    macOS: $(sw_vers -productVersion 2>/dev/null || echo 'Unknown') (${MAC_ARCH:-$(uname -m)})"
    elif [[ "$IS_WSL" == "true" ]]; then
        echo "${info}🛡️  WSL Environment Overview:${done}"
        local distro="Linux"
        command -v lsb_release &>/dev/null && distro=$(lsb_release -ds 2>/dev/null)
        echo "    Distro: ${distro} | Kernel: $(uname -r)"
    else
        echo "${info}🛡️  Linux Environment Overview:${done}"
        local distro="Linux"
        command -v lsb_release &>/dev/null && distro=$(lsb_release -ds 2>/dev/null)
        echo "    Distro: ${distro} | Kernel: $(uname -r)"
    fi

    # --- Shell Versions ---
    local bash_ver
    bash_ver=$(bash --version 2>/dev/null | awk 'NR==1{print $4}' | cut -d'(' -f1)
    echo "    Shell: zsh ${ZSH_VERSION} | bash ${bash_ver}"

    # --- Disk Space ---
    local disk_info=$(_get_disk_usage)
    local disk_pct="${disk_info%%:*}"
    local disk_free="${disk_info##*:}"

    if [[ "$disk_pct" -ge "$ZSH_WELCOME_DISK_WARN" ]]; then
        echo "    Disk: ${warn}${disk_pct}% used${done} (${disk_free} free) ⚠️"
    else
        echo "    Disk: ${disk_pct}% used (${disk_free} free)"
    fi

    # --- uv (Python) ---
    if command -v uv &>/dev/null; then
        local uv_version=$(uv --version 2>/dev/null | awk '{print $2}')
        local uv_python_path=""
        if command -v get_uv_python_path &>/dev/null; then
            uv_python_path=$(get_uv_python_path "${PYTHON_DEFAULT_VERSION}" 2>/dev/null)
        fi
        if [[ -n "$uv_python_path" && -x "$uv_python_path" ]]; then
            local uv_python_version=$("$uv_python_path" --version 2>/dev/null)
            echo "    uv: ${ok}${uv_version}${done} (Python ${PYTHON_DEFAULT_VERSION}: ${uv_python_version})"
        else
            echo "    uv: ${ok}${uv_version}${done} (Python ${PYTHON_DEFAULT_VERSION}: ${warn}not installed${done})"
        fi
    else
        echo "    uv: ${err}Not Found${done}"
    fi

    # --- Node.js ---
    if command -v nvm &>/dev/null; then
        local active_node=$(nvm current 2>/dev/null)
        if [[ "$active_node" == "none" || -z "$active_node" ]]; then
            local default_node=$(nvm version default 2>/dev/null)
            echo "    Node: ${warn}None active${done} (default: ${default_node:-N/A})"
        else
            echo "    Node: ${ok}${active_node}${done}"
        fi
    else
        echo "    Node: ${err}nvm not found${done}"
    fi

    # --- pnpm ---
    if command -v pnpm &>/dev/null; then
        local pnpm_ver=$(pnpm -v 2>/dev/null || echo 'N/A')
        local pnpm_display="${ok}${pnpm_ver}${done}"
        # Soft staleness nudge -- helpers defined in .zsh_onboarding (loaded earlier).
        if [[ "$pnpm_ver" != "N/A" ]] && typeset -f _pnpm_get_latest &>/dev/null; then
            local pnpm_latest pnpm_raw
            pnpm_latest=$(_pnpm_get_latest 2>/dev/null)   # latest eligible (age-gated)
            pnpm_raw=$(_pnpm_get_raw_latest 2>/dev/null)  # registry dist-tag latest
            if [[ -n "$pnpm_latest" \
                  && "$(_pnpm_vercmp "$pnpm_ver" "$pnpm_latest")" == "-1" ]]; then
                # Behind an installable version -- actionable nag.
                if [[ "$(_pnpm_vercmp "$pnpm_ver" "$PNPM_MIN_VERSION")" == "-1" ]]; then
                    pnpm_display="${err}${pnpm_ver}${done} ${err}↑${pnpm_latest} (below min ${PNPM_MIN_VERSION} -- run pnpm_update)${done}"
                else
                    pnpm_display="${ok}${pnpm_ver}${done} ${warn}↑${pnpm_latest} (run pnpm_update)${done}"
                fi
            elif [[ -n "$pnpm_raw" && "$pnpm_raw" != "$pnpm_ver" \
                    && "$(_pnpm_vercmp "$pnpm_ver" "$pnpm_raw")" == "-1" ]]; then
                # At the latest eligible, but a newer version is held by the age gate.
                pnpm_display="${ok}${pnpm_ver}${done} ${info}(latest eligible; ${pnpm_raw} pending release-age gate)${done}"
            fi
        fi
        # Supply-chain settings from ~/.config/pnpm/config.yaml (pnpm 11+ only).
        # Direct file read — faster than `pnpm config get` and shows what's
        # configured globally, ignoring per-project pnpm-workspace.yaml overrides.
        local pnpm_settings=""
        if [[ "$pnpm_ver" != "N/A" ]] && [[ "${pnpm_ver%%.*}" -ge 11 ]]; then
            # Look at the path pnpm actually reads. On macOS that's
            # ~/Library/Preferences/pnpm/; on Linux/WSL that's ~/.config/pnpm/.
            # Source: pnpm.mjs getConfigDir().
            local cfg
            if [[ "$IS_MAC" == "true" && -f "$HOME/Library/Preferences/pnpm/config.yaml" ]]; then
                cfg="$HOME/Library/Preferences/pnpm/config.yaml"
            else
                cfg="${XDG_CONFIG_HOME:-$HOME/.config}/pnpm/config.yaml"
            fi
            if [[ -f "$cfg" ]]; then
                local min_age block_exotic age_human=""
                # Match camelCase (required) or kebab-case (repo may have either).
                min_age=$(grep -E '^(minimum-release-age|minimumReleaseAge):' "$cfg" 2>/dev/null | awk '{print $2}' | head -1)
                block_exotic=$(grep -E '^(block-exotic-subdeps|blockExoticSubdeps):' "$cfg" 2>/dev/null | awk '{print $2}' | head -1)
                # Convert minutes to most-significant human unit.
                if [[ -n "$min_age" ]]; then
                    if   (( min_age == 0 ));    then age_human="off"
                    elif (( min_age < 60 ));    then age_human="${min_age}m"
                    elif (( min_age % 1440 == 0 )); then age_human="$((min_age / 1440))d"
                    elif (( min_age % 60 == 0 ));   then age_human="$((min_age / 60))h"
                    else age_human="${min_age}m"
                    fi
                fi
                local -a parts=()
                [[ -n "$age_human" ]]     && parts+=("minReleaseAge: ${age_human}")
                [[ -n "$block_exotic" ]] && parts+=("blockExoticSubdeps: ${block_exotic}")
                (( ${#parts[@]} > 0 )) && pnpm_settings=" ${info}(${(j:, :)parts})${done}"
            fi
        fi
        echo "    pnpm: ${pnpm_display}${pnpm_settings}"
    else
        echo "    pnpm: ${err}Not Found${done}"
    fi

    # --- bun ---
    if command -v bun &>/dev/null; then
        local bun_ver=$(bun --version 2>/dev/null || echo 'N/A')
        echo "    bun:  ${ok}${bun_ver}${done}"
    else
        echo "    bun:  ${err}Not Found${done}"
    fi

    # --- Docker ---
    if command -v docker &>/dev/null; then
        local docker_running=false
        docker ps &>/dev/null 2>&1 && docker_running=true

        local engine_ver
        if [[ "$docker_running" == true ]]; then
            engine_ver=$(docker version --format '{{.Server.Version}}' 2>/dev/null || echo 'N/A')
            echo "    Docker Engine: ${ok}${engine_ver} (Running)${done}"
        else
            engine_ver=$(docker version --format '{{.Client.Version}}' 2>/dev/null)
            if [[ -z "$engine_ver" ]]; then
                engine_ver=$(docker --version 2>/dev/null | awk '{print $3}' | tr -d ',')
            fi
            : ${engine_ver:=N/A}
            if [[ "$IS_MAC" == "true" ]]; then
                echo "    Docker Engine: ${warn}${engine_ver} (Not Running)${done}"
            else
                echo "    Docker Engine: ${warn}${engine_ver} (Not Running)${done} (try: sudo usermod -aG docker \$USER)"
            fi
        fi

        if [[ "$IS_MAC" == "true" && -d "/Applications/Docker.app" ]]; then
            local desktop_ver
            desktop_ver=$(defaults read /Applications/Docker.app/Contents/Info.plist CFBundleShortVersionString 2>/dev/null || echo 'N/A')
            echo "    Docker Desktop: ${ok}${desktop_ver}${done}"
        fi
    else
        echo "    Docker Engine: ${err}Not Installed${done}"
    fi

    # --- Package manager ---
    if [[ "$IS_MAC" == "true" ]]; then
        if command -v brew &>/dev/null; then
            echo "    Homebrew: ${ok}OK${done}"
        else
            echo "    Homebrew: ${err}Not Found${done}"
        fi
    elif [[ "$IS_WSL" == "true" || "$IS_LINUX" == "true" ]]; then
        if   command -v apt    &>/dev/null; then echo "    Package mgr: ${ok}apt${done}"
        elif command -v dnf    &>/dev/null; then echo "    Package mgr: ${ok}dnf${done}"
        elif command -v pacman &>/dev/null; then echo "    Package mgr: ${ok}pacman${done}"
        elif command -v zypper &>/dev/null; then echo "    Package mgr: ${ok}zypper${done}"
        else echo "    Package mgr: ${warn}none detected${done}"
        fi
    fi

    # --- GPU (WSL/Linux only) ---
    if [[ "$IS_WSL" == "true" || "$IS_LINUX" == "true" ]]; then
        local gpu_status=$(_check_gpu)
        if [[ "$gpu_status" == "available" ]]; then
            echo "    GPU: ${ok}NVIDIA Available${done}"
        else
            echo "    GPU: ${warn}Not Detected${done}"
        fi
    fi
}

# ------------------------------------------------------------------------------
# Minimal Welcome Display (Single Line)
# ------------------------------------------------------------------------------
_show_welcome_minimal() {
    local parts=()

    # OS
    if [[ "$IS_MAC" == "true" ]]; then
        parts+=("macOS ${MAC_ARCH:-$(uname -m)}")
    elif [[ "$IS_WSL" == "true" ]]; then
        parts+=("WSL")
    else
        parts+=("Linux")
    fi

    # Disk
    local disk_info=$(_get_disk_usage)
    local disk_pct="${disk_info%%:*}"
    if [[ "$disk_pct" -ge "$ZSH_WELCOME_DISK_WARN" ]]; then
        parts+=("${warn}Disk ${disk_pct}%${done}")
    else
        parts+=("Disk ${disk_pct}%")
    fi

    # uv
    if command -v uv &>/dev/null; then
        parts+=("${ok}uv ✓${done}")
    else
        parts+=("${err}uv ✗${done}")
    fi

    # Node
    if command -v nvm &>/dev/null; then
        local node_ver=$(nvm current 2>/dev/null)
        if [[ -n "$node_ver" && "$node_ver" != "none" ]]; then
            parts+=("${ok}Node ${node_ver%%.*}${done}")
        else
            parts+=("${warn}Node -${done}")
        fi
    else
        parts+=("${err}Node ✗${done}")
    fi

    # Docker
    if command -v docker &>/dev/null && docker ps &>/dev/null 2>&1; then
        parts+=("${ok}Docker ✓${done}")
    else
        parts+=("${warn}Docker -${done}")
    fi

    # Homebrew (Mac only)
    if [[ "$IS_MAC" == "true" ]]; then
        if command -v brew &>/dev/null; then
            parts+=("${ok}Brew ✓${done}")
        fi
    fi

    # GPU (WSL/Linux only)
    if [[ "$IS_WSL" == "true" || "$IS_LINUX" == "true" ]]; then
        if [[ "$(_check_gpu)" == "available" ]]; then
            parts+=("${ok}GPU ✓${done}")
        fi
    fi

    echo "🛡️  ${(j: | :)parts}"
}

# ------------------------------------------------------------------------------
# Quick Reference — Full
# ------------------------------------------------------------------------------
_show_quickref_full() {
    echo
    echo "${info}🚀  Quick Reference:${done}"
    echo "    Python:  python_new_project, python_setup, python_delete"
    echo "    uv CLI:  uv_tool_install_current_project, uv_tool_check_current_project"
    echo "    Node:    node_new_project, node_setup, node_clean"
    echo "    Git/Docker: lg, lzd | Docker: docker_help | Tmux: tdev, gs, gstatus"
    echo "    Media:   yt --help"
}

# ------------------------------------------------------------------------------
# Quick Reference — Minimal (Compact 2 Lines)
# ------------------------------------------------------------------------------
_show_quickref_minimal() {
    echo
    echo "${info}💡 Python: python_new_project | Node: node_new_project | Docker: docker_help${done}"
    echo "   Tmux: tdev, gs | Git/Docker: lg, lzd | Media: yt --help"
}

# ------------------------------------------------------------------------------
# Main Execution
# ------------------------------------------------------------------------------

# Show welcome based on verbosity
case "$_WELCOME_VERBOSITY" in
    full)
        _show_welcome_full
        ;;
    minimal)
        _show_welcome_minimal
        ;;
    none|"")
        # No welcome output
        ;;
esac

# Show quick reference based on its own verbosity setting
# (Only show if welcome is not 'none' — if user wants no welcome, probably wants no quickref either)
if [[ "$_WELCOME_VERBOSITY" != "none" ]]; then
    case "$ZSH_WELCOME_QUICKREF" in
        full)
            _show_quickref_full
            ;;
        minimal)
            _show_quickref_minimal
            ;;
        none|"")
            # No quick reference output
            ;;
    esac
fi

# Add blank line for spacing (only if we showed something)
if [[ "$_WELCOME_VERBOSITY" != "none" ]]; then
    echo
fi

# ------------------------------------------------------------------------------
# uv Python Install Prompt
# ------------------------------------------------------------------------------
# Only prompt if:
# 1. Welcome verbosity is 'full' (not in SSH/tmux quick mode)
# 2. Shell is interactive
# 3. Python version is actually missing
if [[ "$_WELCOME_VERBOSITY" == "full" ]]; then
    if command -v get_uv_python_path &>/dev/null && ! get_uv_python_path "${PYTHON_DEFAULT_VERSION}" &>/dev/null; then
        echo "${warn}⚠️  Default Python (${PYTHON_DEFAULT_VERSION}) not found in 'uv' cache.${done}"
        if [[ -t 1 ]]; then
            read "REPLY?    👉 Would you like to run 'uv python install python@${PYTHON_DEFAULT_VERSION}' now? [y/N] "
            case "$REPLY" in
                [yY][eE][sS]|[yY])
                    uv python install "python@${PYTHON_DEFAULT_VERSION}"
                    ;;
                *)
                    echo "${warn}    Skipping 'uv' Python installation.${done}"
                    ;;
            esac
        fi
    fi
fi

# Cleanup internal variables
unset _WELCOME_VERBOSITY
