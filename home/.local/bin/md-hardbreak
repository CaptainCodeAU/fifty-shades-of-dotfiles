#!/usr/bin/env perl
# =============================================================================
# md-hardbreak - on-demand Markdown formatting for Zed (and any previewer)
# =============================================================================
#
# PURPOSE
#   Keep a Markdown SOURCE file clean and readable while making its rendered
#   PREVIEW show the line and paragraph structure you actually typed.
#
# WHY THIS EXISTS (verified against the zed-industries/zed source)
#   Zed's markdown preview follows CommonMark, so by default:
#     - a single newline inside a paragraph collapses to a SPACE (your separate
#       lines run together onto one line), and
#     - a blank line is only a paragraph break; the gap's size is hardcoded
#       (mb_2 / line-height rems(1.3) in crates/markdown) with NO user setting.
#   buffer_line_height only changes the scroll step; ui_font_size scales the
#   whole UI. So the one real lever is the source markup itself - which is what
#   this script edits, using characters that stay invisible (or nearly so) in
#   the raw file but change what the renderer draws.
#
# WHAT IT DOES - three composable feature flags
#   --breaks   Append two trailing spaces BETWEEN continuing lines of a block,
#              so a single source newline renders as a line break.
#   --gaps     Insert one U+2800 (braille blank) empty paragraph at each
#              blank-line block boundary, so a blank line renders as a visible
#              empty row.
#   --strip    The inverse: remove the breaks + gaps this tool added, returning
#              clean source (also collapses runs of blank lines to a single one).
#
#   Flags combine. With NO feature flag the default is --breaks (backward
#   compatible). --strip ignores --breaks/--gaps.
#
# MODES
#   md-hardbreak [flags] FILE [FILE ...]   edit Markdown file(s) in place
#   md-hardbreak [flags] --stdin           filter: read stdin, write stdout
#   md-hardbreak [flags] -                 same as --stdin
#   md-hardbreak FILE                      no flag == --breaks
#
# EXAMPLES
#   md-hardbreak --breaks notes.md             # hard breaks only
#   md-hardbreak --gaps notes.md               # gaps only
#   md-hardbreak --breaks --gaps notes.md      # both
#   md-hardbreak --strip notes.md              # undo -> clean source
#   md-hardbreak --breaks --gaps a.md b.md     # several files at once
#   pbpaste | md-hardbreak --breaks --gaps -   # pipe text through (to stdout)
#
# ZED KEY BINDINGS (in home/.config/zed/keymap.json, stow-symlinked to
# ~/.config/zed/keymap.json; they spawn the tasks in home/.config/zed/tasks.json):
#   cmd-alt-b   "Markdown: add 2-space line breaks"          -> --breaks
#   cmd-alt-g   "Markdown: add line breaks + paragraph gaps" -> --breaks --gaps
#   cmd-alt-u   "Markdown: strip line breaks + gaps"         -> --strip
#   NOTE: after editing tasks.json or keymap.json, reload Zed so it sees them.
#
# RULES / DECISIONS / NUANCES
#   - ON-DEMAND ONLY: there is no on-save trigger. Markdown format_on_save is
#     "off" in Zed settings, so saving leaves the file exactly as typed. (It was
#     "on" = Prettier-on-save before 2026-06-20, in place since 2026-05-03; we
#     may revert, but only after tweaking Prettier so it stops indenting lazy
#     list continuations first.)
#   - IDEMPOTENT: running any mode a second time changes nothing.
#   - A hard break is NEVER left on a block's LAST line. A trailing break there
#     is a no-op in Zed but becomes an extra <br> in lenient previewers, which -
#     combined with a gap paragraph - renders as a DOUBLE gap. So a break is only
#     added between two continuing non-blank lines of the same block.
#   - Gaps are CONSERVATIVE: a gap is inserted at a blank boundary UNLESS it
#     would split a list (both neighbors are list items) or sits next to a
#     heading, hr, code fence, blockquote, or an existing gap. Never inside a
#     fenced code block or YAML frontmatter.
#   - GAP CHARACTER = U+2800 (braille pattern blank). Why this one:
#       * U+2800, U+200B (zero-width space) and U+2060 (word joiner) all render
#         as a gap AND survive Prettier; U+00A0 (no-break space) and U+FEFF (BOM)
#         get STRIPPED by Prettier, so they are unusable.
#       * U+2800 is the least likely to trip security scanners / code review (it
#         is a normal letter-like glyph with width), unlike the true zero-width
#         characters - which are the same ones used for hidden-text / homograph
#         attacks. The owner is deliberately wary of invisible characters as a
#         blanket policy precedent, so U+2800 is the cautious choice.
#   - A line jammed directly under a "- " bullet with NO blank line is a
#     list-item CONTINUATION in Markdown; put blank lines around it to make it a
#     standalone paragraph that can take its own gaps.
#   - File mode only edits Markdown extensions (.md .markdown .mdx .mdown .mkd
#     .mkdn); anything else is skipped with a warning.
#   - The Zed settings.json that sets format_on_save off is skip-worktree, so
#     that part is Mac-local and not committed.
#
# SEE ALSO
#   ~/.config/zed/tasks.json   - the Zed tasks that invoke this script
#   home/.config/zed/keymap.json  - the cmd-alt-b / -g / -u bindings (committed)
# =============================================================================

use strict;
use warnings;

my $GAP = "\x{2800}";   # U+2800 BRAILLE PATTERN BLANK

sub is_blank     { my $l = shift; return $l =~ /^[ \t]*$/; }
sub is_list_item { my $l = shift; return $l =~ /^\s*([-*+]|\d+[.)])\s/; }

# A neighbor next to which we must NOT insert a gap.
sub gap_blocked {
    my $l = shift;
    return 1 if $l =~ /^\s{0,3}#{1,6}\s/;                       # heading
    return 1 if $l =~ /^(-{3,}|={3,}|\*{3,}|_{3,}|\.{3})\s*$/;  # hr / setext / frontmatter
    return 1 if $l =~ /^\s*(```|~~~)/;                          # code fence
    return 1 if $l =~ /^\s*>/;                                  # blockquote
    return 1 if $l =~ /\x{2800}/;                               # already a gap line
    return 0;
}

# Split raw lines into bodies/eols and mark code-fence + frontmatter regions.
sub scan {
    my ($raw) = @_;
    my $n = scalar @$raw;
    my @body = map { my $x = $_; $x =~ s/\R\z//; $x } @$raw;
    my @eol  = map { ($_ =~ /(\R)\z/) ? $1 : "\n" } @$raw;
    my (@incode, @infront);
    my ($code, $front) = (0, 0);
    for my $i (0 .. $n - 1) {
        my $b = $body[$i];
        if ($i == 0 && $b =~ /^---\s*$/) { $front = 1; $infront[$i] = 1; $incode[$i] = 0; next; }
        if ($front) { $infront[$i] = 1; $incode[$i] = 0; $front = 0 if $b =~ /^(---|\.\.\.)\s*$/; next; }
        $infront[$i] = 0;
        if ($b =~ /^\s*(```|~~~)/) { $incode[$i] = 1; $code = !$code; next; }
        $incode[$i] = $code ? 1 : 0;
    }
    return (\@body, \@eol, \@incode, \@infront);
}

# Apply hard breaks (if $do_breaks) and gaps (if $do_gaps) in place.
sub format_md {
    my ($lines_ref, $do_breaks, $do_gaps) = @_;
    my ($body, $eol, $incode, $infront) = scan($lines_ref);
    my $n = scalar @$body;
    my @out;
    my $changed = 0;
    my $i = 0;
    while ($i < $n) {
        my $b = $body->[$i];

        if (!$incode->[$i] && !$infront->[$i] && is_blank($b)) {
            my $j = $i;
            $j++ while ($j < $n && !$incode->[$j] && !$infront->[$j] && is_blank($body->[$j]));
            my $pnb;
            for (my $k = $#out; $k >= 0; $k--) {
                (my $bb = $out[$k]) =~ s/\R\z//;
                if ($bb !~ /^[ \t]*$/) { $pnb = $bb; last; }
            }
            my $nnb = ($j < $n) ? $body->[$j] : undef;
            if ($do_gaps && defined $pnb && defined $nnb
                && !gap_blocked($pnb) && !gap_blocked($nnb)
                && !(is_list_item($pnb) && is_list_item($nnb))) {
                push @out, "\n", $GAP . "\n", "\n";
                $changed++;
            } else {
                push @out, ($lines_ref->[$_]) for ($i .. $j - 1);
            }
            $i = $j;
            next;
        }

        my $e = $eol->[$i];
        if ($incode->[$i] || $infront->[$i]) { push @out, $b . $e; }
        elsif ($b =~ /^\s*(```|~~~)/)   { push @out, $b . $e; }
        elsif ($b =~ /^\s*#{1,6}\s/)    { push @out, $b . $e; }
        elsif ($b =~ /\\$/)             { push @out, $b . $e; }   # explicit backslash break
        elsif ($b =~ /\x{2800}/)        { push @out, $b . $e; }   # existing gap marker line
        elsif ($do_breaks) {
            (my $nb = $b) =~ s/[ \t]+$//;
            my $next_continues = ($i + 1 < $n) && !is_blank($body->[$i + 1])
                                 && !$incode->[$i + 1] && !$infront->[$i + 1];
            my $line = $next_continues ? $nb . "  " . $e : $nb . $e;
            push @out, $line;
            $changed++ if $line ne ($b . $e);
        }
        else { push @out, $b . $e; }   # breaks off -> leave prose untouched
        $i++;
    }
    @$lines_ref = @out;
    return $changed;
}

# Remove md-hardbreak hard breaks + gaps -> clean source.
sub strip_md {
    my ($lines_ref) = @_;
    my ($body, $eol, $incode, $infront) = scan($lines_ref);
    my $n = scalar @$body;
    my @out;
    my $changed = 0;
    my $i = 0;
    while ($i < $n) {
        my $b = $body->[$i];
        my $e = $eol->[$i];
        if ($incode->[$i] || $infront->[$i]) { push @out, $b . $e; $i++; next; }

        if (is_blank($b)) {                       # collapse a blank run to one blank
            my $j = $i;
            $j++ while ($j < $n && !$incode->[$j] && !$infront->[$j] && is_blank($body->[$j]));
            push @out, "\n";
            $changed++ if ($j - $i) > 1;
            $i = $j;
            next;
        }
        if ($b =~ /^\s*\x{2800}\s*$/) {           # drop gap marker (+ one trailing blank)
            $changed++;
            $i++;
            if ($i < $n && !$incode->[$i] && is_blank($body->[$i])
                && @out && $out[-1] =~ /^[ \t]*\R?$/) { $i++; }
            next;
        }
        (my $nb = $b) =~ s/[ \t]+$//;             # strip trailing ws (removes 2-space breaks)
        $changed++ if $nb ne $b;
        push @out, $nb . $e;
        $i++;
    }
    @$lines_ref = @out;
    return $changed;
}

# ---- arguments ----
my %flag  = map { $_ => 1 } grep { /^--/ || $_ eq '-' } @ARGV;
my @files = grep { !/^--/ && $_ ne '-' } @ARGV;
my $do_strip  = $flag{'--strip'};
my $do_breaks = $flag{'--breaks'};
my $do_gaps   = $flag{'--gaps'};
$do_breaks = 1 if !$do_strip && !$do_breaks && !$do_gaps;   # default: hard breaks

sub run {
    my ($lines_ref) = @_;
    return $do_strip ? strip_md($lines_ref) : format_md($lines_ref, $do_breaks, $do_gaps);
}

my $want_stdin = $flag{'--stdin'} || $flag{'-'} || !@files;
if ($want_stdin && !@files) {
    binmode STDIN,  ':encoding(UTF-8)';
    binmode STDOUT, ':encoding(UTF-8)';
    my @lines = <STDIN>;
    run(\@lines);
    print @lines;
    exit 0;
}

@files or die "usage: md-hardbreak [--breaks] [--gaps] [--strip] FILE ...  |  ... --stdin\n";

for my $file (@files) {
    unless ($file =~ /\.(md|markdown|mdx|mdown|mkd|mkdn)$/i) {
        warn "md-hardbreak: skipping non-Markdown file: $file\n";
        next;
    }
    open(my $in, '<:encoding(UTF-8)', $file) or do { warn "md-hardbreak: cannot read $file: $!\n"; next };
    my @lines = <$in>;
    close $in;
    my $changed = run(\@lines);
    if ($changed) {
        open(my $out, '>:encoding(UTF-8)', $file) or do { warn "md-hardbreak: cannot write $file: $!\n"; next };
        print {$out} @lines;
        close $out;
        print "md-hardbreak: $file — ", ($do_strip ? "stripped" : "formatted"), " ($changed edit(s))\n";
    } else {
        print "md-hardbreak: $file — nothing to do\n";
    }
}
