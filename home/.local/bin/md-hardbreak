#!/usr/bin/env perl
# md-hardbreak v3 — two transforms for Markdown so the source stays readable but
# the PREVIEW shows line structure:
#   (1) hard breaks: append two trailing spaces to prose lines (single newline
#       renders as a line break).
#   (2) gaps: a blank line BETWEEN TWO PLAIN PROSE PARAGRAPHS becomes a visible
#       empty row, by inserting one U+2800 (braille blank) as its own paragraph.
#
# Conservative + idempotent. The gap is inserted ONLY when the blank run is
# sandwiched between two ordinary prose lines, so it never disturbs:
#   lists, blockquotes, tables, headings, fenced/indented code, YAML frontmatter,
#   or an existing U+2800 gap.
#
# Hard breaks run ALWAYS; gaps run ONLY with --gaps. This lets on-save stay
# hard-breaks-only (no invisible characters injected automatically) while the
# gap insertion is a deliberate, manual action you trigger yourself.
#
# Modes:
#   md-hardbreak FILE [FILE ...]            edit Markdown file(s) in place (hard breaks)
#   md-hardbreak --gaps FILE [FILE ...]     also insert U+2800 paragraph gaps
#   md-hardbreak --stdin [--gaps]           filter mode (Zed external formatter / tasks)

use strict;
use warnings;

my $GAP = "\x{2800}";   # U+2800 BRAILLE PATTERN BLANK

sub is_blank { my $l = shift; return $l =~ /^[ \t]*$/; }

# An ordinary paragraph line that may sit next to an inserted gap.
sub is_plain_prose {
    my $l = shift;
    return 0 if $l =~ /^[ \t]*$/;                 # blank
    return 0 if $l =~ /^\s{0,3}#{1,6}\s/;         # ATX heading
    return 0 if $l =~ /^\s*([-*+]|\d+[.)])\s/;    # list item
    return 0 if $l =~ /^\s*>/;                    # blockquote
    return 0 if $l =~ /\|/;                       # table / pipe
    return 0 if $l =~ /^\s*(```|~~~)/;            # code fence
    return 0 if $l =~ /^ {4,}/ || $l =~ /^\t/;    # indented code
    return 0 if $l =~ /^(-{3,}|\.{3}|={3,}|\*{3,}|_{3,})\s*$/; # hr/setext/frontmatter
    return 0 if $l =~ /\x{2800}/;                 # already a gap line
    return 1;
}

# transform an array of raw lines (each may carry its own EOL) in place.
sub harden {
    my ($lines_ref, $do_gaps) = @_;
    my @raw = @$lines_ref;
    my $n = scalar @raw;
    my @body = map { my $x = $_; $x =~ s/\R\z//; $x } @raw;
    my @eol  = map { ($_ =~ /(\R)\z/) ? $1 : "\n" } @raw;

    # mark code-fence and frontmatter regions over original lines
    my (@incode, @infront);
    my ($code, $front) = (0, 0);
    for my $i (0 .. $n - 1) {
        my $b = $body[$i];
        if ($i == 0 && $b =~ /^---\s*$/) { $front = 1; $infront[$i] = 1; $incode[$i] = 0; next; }
        if ($front) { $infront[$i] = 1; $incode[$i] = 0; $front = 0 if $b =~ /^(---|\.\.\.)\s*$/; next; }
        $infront[$i] = 0;
        if ($b =~ /^\s*(```|~~~)/) { $incode[$i] = 1; $code = !$code; next; }
        $incode[$i] = $code ? 1 : 0;
    }

    my @out;
    my $changed = 0;
    my $i = 0;
    while ($i < $n) {
        my $b = $body[$i];

        # blank run, outside code/frontmatter -> maybe a gap
        if (!$incode[$i] && !$infront[$i] && is_blank($b)) {
            my $j = $i;
            $j++ while ($j < $n && !$incode[$j] && !$infront[$j] && is_blank($body[$j]));
            my $pnb;
            for (my $k = $#out; $k >= 0; $k--) {
                (my $bb = $out[$k]) =~ s/\R\z//;
                if ($bb !~ /^[ \t]*$/) { $pnb = $bb; last; }
            }
            my $nnb = ($j < $n) ? $body[$j] : undef;
            if ($do_gaps && defined $pnb && defined $nnb && is_plain_prose($pnb) && is_plain_prose($nnb)) {
                push @out, "\n", $GAP . "\n", "\n";
                $changed++;
            } else {
                push @out, ($raw[$_]) for ($i .. $j - 1);   # preserve original blanks
            }
            $i = $j;
            next;
        }

        # non-blank, or inside code/frontmatter
        my $e = $eol[$i];
        if ($incode[$i] || $infront[$i]) {
            push @out, $b . $e;
        }
        elsif ($b =~ /^\s*(```|~~~)/)   { push @out, $b . $e; }
        elsif ($b =~ /^\s*#{1,6}\s/)    { push @out, $b . $e; }
        elsif ($b =~ /  $/ || $b =~ /\\$/) { push @out, $b . $e; }
        elsif ($b =~ /\x{2800}/)        { push @out, $b . $e; }   # leave gap marker line alone
        else {
            (my $nb = $b) =~ s/\s+$//;
            my $line = $nb . "  " . $e;
            push @out, $line;
            $changed++ if $line ne ($b . $e);
        }
        $i++;
    }

    @$lines_ref = @out;
    return $changed;
}

my @files = grep { $_ ne '-' && $_ ne '--stdin' && $_ ne '--gaps' } @ARGV;
my $do_gaps = grep { $_ eq '--gaps' } @ARGV;
my $stdin_mode = (!@files && (grep({ $_ eq '-' || $_ eq '--stdin' } @ARGV) || !@ARGV));

if ($stdin_mode) {
    binmode STDIN,  ':encoding(UTF-8)';
    binmode STDOUT, ':encoding(UTF-8)';
    my @lines = <STDIN>;
    harden(\@lines, $do_gaps);
    print @lines;
    exit 0;
}

@files or die "usage: md-hardbreak FILE [FILE ...]  |  md-hardbreak --stdin < in > out\n";

for my $file (@files) {
    unless ($file =~ /\.(md|markdown|mdx|mdown|mkd|mkdn)$/i) {
        warn "md-hardbreak: skipping non-Markdown file: $file\n";
        next;
    }
    open(my $in, '<:encoding(UTF-8)', $file) or do { warn "md-hardbreak: cannot read $file: $!\n"; next };
    my @lines = <$in>;
    close $in;
    my $changed = harden(\@lines, $do_gaps);
    if ($changed) {
        open(my $out, '>:encoding(UTF-8)', $file) or do { warn "md-hardbreak: cannot write $file: $!\n"; next };
        print {$out} @lines;
        close $out;
        print "md-hardbreak: $file — $changed edit(s)\n";
    } else {
        print "md-hardbreak: $file — nothing to do\n";
    }
}
