# ==============================================================================
#  Global Git Configuration (generic / shareable)
# ==============================================================================
# This is a public-safe template managed by GNU Stow. Personal info (name,
# email, signing keys) lives in a separate private file that is NOT committed:
#
#   ~/.gitconfig.private
#
# Create it with:
#   [user]
#       name = Your Name
#       email = you@example.com
#
# SSH-Only Authentication
# -----------------------
# This system enforces SSH-only authentication for GitHub. HTTPS credential
# helpers have been intentionally removed. All HTTPS GitHub URLs for YOUR
# accounts are rewritten to SSH via scoped [url] insteadOf rules in
# ~/.gitconfig.private. Third-party URLs (Homebrew, open-source repos)
# stay on HTTPS and work without authentication.
#
#   [url "<your-ssh-host-alias>:<YourGitHubUsername>/"]
#       insteadOf = https://github.com/<YourGitHubUsername>/
#   [url "<your-ssh-host-alias>:"]
#       insteadOf = https://gist.github.com/<YourGitHubUsername>/
#
# Per-account git identities live alongside their SSH keys in ~/.ssh/
# and are loaded via includeIf rules in ~/.gitconfig.private.
# See ~/.gitconfig.private for the full account setup and instructions.
#
# WARNING: Running `gh auth login` or `gh auth setup-git` will silently
# re-add HTTPS credential helpers to this file. If that happens, remove
# the [credential "https://github.com"] and [credential "https://gist..."]
# sections that get added.
#
# The [include] below loads it automatically. The file is protected by
# .gitignore_global so it will never be accidentally committed.

[include]
	path = ~/.gitconfig.private

[color]
	ui = auto

[init]
	defaultbranch = master

[pull]
	ff = only

[push]
	autoSetupRemote = true

[core]
	excludesfile = ~/.gitignore_global
	editor = cursor --wait

[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[diff]
	colorMoved = default

[merge]
	conflictstyle = diff3

[rerere]
	enabled = true
