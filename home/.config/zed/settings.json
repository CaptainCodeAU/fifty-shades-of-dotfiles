{
	// Window behavior

	// ============================================================================
	// AI / EDIT PREDICTIONS — DISABLED
	// ============================================================================
	// disable_ai: master kill switch. Disables the agent panel, inline ghost-text
	//   predictions, model dropdowns — everything AI-powered in Zed.
	//   Set to false to re-enable AI features.
	// show_edit_predictions: controls just the ghost-text predictions while typing.
	//   When disable_ai is true this is redundant — kept here as belt-and-braces
	//   so it stays disabled even if disable_ai is flipped back to false.
	// edit_predictions.provider: which prediction model would run ("zed" = Zeta,
	//   Zed's own model). Only takes effect when AI is re-enabled.
	// ============================================================================
	"disable_ai": true,
	"show_edit_predictions": false,
	"edit_predictions": {
		"provider": "zed",
	},

	"project_panel": {
		"dock": "left"
	},
	"outline_panel": {
		"dock": "left"
	},
	"collaboration_panel": {
		"dock": "left"
	},
	// ============================================================================
	// AGENT PANEL — readable width when AI is re-enabled
	// ============================================================================
	// dock: where to place the agent panel ("left" | "right" | "bottom").
	// limit_content_width: when true, prose in the agent panel is capped at
	//   max_content_width and centered if the panel is wider — keeps lines
	//   from running edge-to-edge on a wide display.
	// max_content_width: pixel cap for the centered content (default 850).
	// NOTE: while disable_ai:true above, the agent panel is hidden so these
	//   settings are dormant — they take effect the moment AI is re-enabled.
	// ============================================================================
	"agent": {
		"dock": "right",
		"favorite_models": [],
		"model_parameters": [],
		"limit_content_width": true,
		"max_content_width": 900,
	},
	"git_panel": {
		"dock": "left"
	},
	"ssh_connections": [
		{
			"host": "mlbox-ubuntu",
			"args": [],
			"projects": [
				{
					"paths": ["/home/winadmin/repos/llmster-server-3090"]
				}
			]
		},
		{
			"host": "192.168.1.101",
			"username": "root",
			"args": [],
			"projects": [
				{
					"paths": ["/root/audit/./"]
				}
			]
		}
	],
	"when_closing_with_no_tabs": "platform_default",

	// Session settings
	"session": {
		"trust_all_worktrees": true
	},

	// Telemetry (disabled)
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},

	// Theme configuration
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "Catppuccin Macchiato"
	},

	// Icon theme
	"icon_theme": {
		"mode": "dark",
		"light": "Zed (Default)",
		"dark": "Catppuccin Macchiato"
	},

	// Keyboard configuration
	"base_keymap": "VSCode",

	// macOS text rendering: "platform_default" | "subpixel" (ClearType) | "grayscale"
	// "subpixel" is the 1.2.0-pre clarity boost for dark themes (like Catppuccin Macchiato).
	"text_rendering_mode": "subpixel",

	// ============================================================================
	// UI FONT — A/B/C COMPARISON BLOCK
	// ============================================================================
	// Uncomment ONE variant at a time. Restart Zed or close+reopen the preview
	// pane (Cmd+Shift+P → "Markdown: Open Preview") after each change.
	//
	//   Variant A — System default (no explicit setting; SF Pro on macOS)
	//   Variant B — Inter (ACTIVE: clean, modern, high x-height)
	//   Variant C — IBM Plex Sans (slightly more character, also very readable)
	// ============================================================================

	// Variant A — System default (ORIGINAL — no ui_font_family set)
	// (Leave all three commented to fall back to this.)

	// Variant B — Inter (ACTIVE)
	"ui_font_family": "Inter",

	// Variant C — IBM Plex Sans
	// "ui_font_family": "IBM Plex Sans",

	// panels, tabs, sidebar, status bar, markdown preview
	"ui_font_size": 14,
	"buffer_font_family": "MonoLisa Nerd Font Mono",
	// editor (your code)
	"buffer_font_size": 12.0,
	// agent panel chrome
	"agent_ui_font_size": 14,

	// Buffer line height — affects code block density inside markdown preview too.
	// "comfortable" = 1.618, "standard" = 1.3. Custom 1.8 opens things up further.
	"buffer_line_height": "comfortable",
	// "buffer_line_height": { "custom": 1.8 },
	// "buffer_line_height": "standard",

	// Terminal settings
	"terminal": {
		"dock": "bottom",
		"env": {},
		"font_size": 11.0,
		"font_family": "JetBrainsMono Nerd Font Mono",
		"font_fallbacks": [".SystemUIFont"],
		"max_scroll_history_lines": 50000,
		"blinking": "terminal_controlled",
		"cursor_shape": "block"
	},

	// ============================================================================
	// MARKDOWN PREVIEW FONT — A/B/C COMPARISON BLOCK
	// ============================================================================
	// Three variants for the preview-pane body font. Uncomment ONE at a time.
	//
	//   Variant A — MonoLisa (matches editor; everything monospace, original feel)
	//   Variant B — Inter (ACTIVE: sans-serif for prose, clean and dense)
	//   Variant C — Charter (serif, book-like reading experience)
	// ============================================================================

	// Variant A — MonoLisa (matches buffer font)
	// "markdown_preview_font_family": "MonoLisa Nerd Font Mono",

	// Variant B — Inter (ACTIVE)
	"markdown_preview_font_family": "Inter",

	// Variant C — Charter (serif)
	// "markdown_preview_font_family": "Charter",

	// Syntax theme for code blocks inside the preview pane.
	// Independent of your editor theme — swap to taste.
	"markdown_preview_theme": "Catppuccin Macchiato",
	// "markdown_preview_theme": "One Dark",
	// "markdown_preview_theme": "Ayu Dark",

	// Editor settings
	"colorize_brackets": true,
	// ============================================================================
	// INDENT GUIDES — colored per indent level (pairs with rainbow brackets)
	// ============================================================================
	// coloring: "fixed" | "indent_aware" — indent_aware varies hue by depth.
	// background_coloring: "disabled" | "indent_aware" — fills the column behind guides.
	// active_line_width thickens the guide for the indent level the cursor is on.
	// ============================================================================
	"indent_guides": {
		"enabled": true,
		"line_width": 1,
		"active_line_width": 2,
		"coloring": "indent_aware",
		"background_coloring": "disabled",
	},
	"linked_edits": true,
	// show_edit_predictions moved up to "AI / EDIT PREDICTIONS — DISABLED" section
	"semantic_tokens": "full",
	"wrap_guides": [90],
	"tab_size": 4,
	"hard_tabs": true,
	"auto_indent_on_paste": true,
	"format_on_save": "on",

	// ============================================================================
	// ACTIVE PANE — dim inactive splits for focus
	// ============================================================================
	// inactive_opacity: 1.0 disables dim, 0.85 subtle, 0.7 obvious, 0.5 dramatic.
	// border_size adds an inset ring (px) around the focused pane.
	// ============================================================================
	"active_pane_modifiers": {
		"border_size": 1.0,
		"inactive_opacity": 0.85,
	},

	// ============================================================================
	// EDITOR TABS — color labels by git status
	// ============================================================================
	// tabs.git_status: true colors tab labels by their git state
	//   (modified / staged / untracked / etc.) using your theme's diff colors.
	// Other tab options exist (file_icons, show_close_button, activate_on_close,
	// show_diagnostics) — leaving them at defaults for now.
	// ============================================================================
	"tabs": {
		"git_status": true,
	},

	// ============================================================================
	// MARKDOWN-SPECIFIC LANGUAGE OVERRIDES
	// ============================================================================
	// soft_wrap + preferred_line_length cap the visual line width in the preview
	// so paragraphs don't run edge-to-edge on a wide monitor.
	// 80 = tight, 100 = standard reading measure, 120 = wide.
	// remove_trailing_whitespace_on_save: false preserves double-space line breaks.
	// ============================================================================
	"languages": {
		"Markdown": {
			"format_on_save": "on",
			"soft_wrap": "editor_width",
			"preferred_line_length": 100,
			"remove_trailing_whitespace_on_save": false
		}
	},

	// Minimap
	"minimap": {
		"show": "never",
	},

	// ============================================================================
	// COLOR PROFILES FOR ZED
	// ============================================================================
	// Uncomment ONE profile below to apply it. Only one can be active at a time.
	// These override the title bar, status bar, panels, and borders.
	// ============================================================================

	// Profile 1 — Ocean Deep (ACTIVE)
	// Modernized syntax: "theme_overrides" (no experimental. prefix), nested under theme name.
	// Applies only when "Catppuccin Macchiato" is the active theme.
	// NOTE: tab_bar.background is the strip CONTAINING the tabs; without overriding it,
	// inactive tabs visually merge with the original bar color and look unchanged.
	"theme_overrides": {
		"Catppuccin Macchiato": {
			"title_bar.background": "#1a4d7a",
			"status_bar.background": "#1a4d7a",
			"title_bar.inactive_background": "#154065",
			"tab_bar.background": "#154065",
			// "tab.inactive_background": "#1a4d7a",
			"panel.focused_border": "#154065",
			"border": "#154065",
			// Border around the focused editor split (subtle, applies on multi-pane layouts)
			"pane.focused_border": "#154065",
			// Borders BETWEEN editor splits (visible only when you have ≥2 editor panes)
			"pane_group.border": "#154065",
			// Optional bonus keys — uncomment if you want even more Ocean Deep coverage:
			// terminal.background paints the terminal panel; bold but unifies with bottom dock
			// "terminal.background": "#154065",
			// tab.active_background defaults to editor.background (#24273a Macchiato);
			// override to make the active tab visually distinct from the editor canvas:
			// "tab.active_background": "#1a4d7a",
		},
	},

