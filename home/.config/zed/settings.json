{
	// Window behavior
	"project_panel": {
  "dock": "left"
 },
 "outline_panel": {
  "dock": "left"
 },
 "collaboration_panel": {
  "dock": "left"
 },
 "agent": {
  "dock": "right",
  "favorite_models": [],
  "model_parameters": []
 },
 "git_panel": {
  "dock": "left"
 },
 "ssh_connections": [
  {
   "host": "mlbox-ubuntu",
   "args": [],
   "projects": [
    {
     "paths": [
      "/home/winadmin/repos/llmster-server-3090"
     ]
    }
   ]
  },
  {
   "host": "192.168.1.101",
   "username": "root",
   "args": [],
   "projects": [
    {
     "paths": [
      "/root/audit/./"
     ]
    }
   ]
  }
 ],
 "when_closing_with_no_tabs": "platform_default",

	// Session settings
	"session": {
		"trust_all_worktrees": true,
	},

	// Telemetry (disabled)
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},

	// Theme configuration
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "Catppuccin Mocha",
	},

	// Icon theme
	"icon_theme": {
		"mode": "dark",
		"light": "Zed (Default)",
		"dark": "Zed (Default)",
	},

	// Keyboard configuration
	"base_keymap": "VSCode",

	// Font settings
	"ui_font_size": 16,
	"buffer_font_family": "MonoLisa Nerd Font Mono",
	"buffer_font_size": 14.0,

	// Editor settings
	"colorize_brackets": true,
	"linked_edits": true,
	"show_edit_predictions": true,
	"semantic_tokens": "full",
	"wrap_guides": [90],
	"tab_size": 4,
	"hard_tabs": true,
	"auto_indent_on_paste": true,
	"format_on_save": "on",

	// Minimap
	"minimap": {
		"show": "never",
	},

	// Terminal settings
	"terminal": {
		"env": {},
		"font_size": 11.0,
		"font_family": "JetBrainsMono Nerd Font Mono",
		"font_fallbacks": ["monospace"],
		"max_scroll_history_lines": 50000,
		"blinking": "terminal_controlled",
		"cursor_shape": "block",
	},

