	// ============================================================================
	// SETTINGS PROFILES — runtime swap (replaces A/B/C comment toggling)
	// ============================================================================
	// Activate via command palette: "settings profile selector: toggle"
	// `base: "default"` ignores user settings; default `base: "user"` layers on top.
	// ============================================================================
	"profiles": {
		"Presenting": {
			"base": "default",
			"settings": {
				"theme": "One Light",
				"ui_font_size": 18,
				"buffer_font_size": 16,
				"agent_ui_font_size": 18,
			},
		},
		"UI-Inter": {
			"settings": {
				"ui_font_family": "Inter",
				"markdown_preview_font_family": "Inter",
			},
		},
		"UI-IBMPlex": {
			"settings": {
				"ui_font_family": "IBM Plex Sans",
				"markdown_preview_font_family": "IBM Plex Sans",
			},
		},
		"Markdown-Charter": {
			"settings": {
				"markdown_preview_font_family": "Charter",
			},
		},
	},
}
