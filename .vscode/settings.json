    "terminal.integrated.suggest.enabled": false,
    "keyboard.dispatch": "keyCode",
    // --- Sounds & Accessibility (grouped + documented) ---
    // Master volume for accessibility signal sounds (0-100).
    "accessibility.signalOptions.volume": 40,
    // Legacy/global audio cues behavior: "auto" plays cues when helpful.
    "audioCues.enabled": "auto",
    // Terminal bell toggle (separate from accessibility signal bell).
    "terminal.integrated.enableVisualBell": false,
    // Chat/agent notification controls.
    // Sound when a chat/agent response is received (re-enabled for your requested case).
    "accessibility.signals.chatResponseReceived": {
        "sound": "on"
    },
    // Sound when a chat/agent request is sent.
    "accessibility.signals.chatRequestSent": {
        "sound": "off"
    },
    // Sound while long-running chat or tool progress is reported.
    "accessibility.signals.progress": {
        "sound": "off"
    },
    // Sound when AI edits modify files.
    "accessibility.signals.chatEditModifiedFile": {
        "sound": "off"
    },
    // Sound when chat/agent requires explicit user action.
    "accessibility.signals.chatUserActionRequired": {
        "sound": "on"
    },
    // Sound when an AI edit batch is kept.
    "accessibility.signals.editsKept": {
        "sound": "off"
    },
    // Sound when an AI edit batch is undone.
    "accessibility.signals.editsUndone": {
        "sound": "off"
    },
    // Terminal and command result controls.
    // Sound when terminal quick fixes become available.
    "accessibility.signals.terminalQuickFix": {
        "sound": "off"
    },
    // Sound for terminal bell events.
    "accessibility.signals.terminalBell": {
        "sound": "off"
    },
    // Sound when a terminal command fails.
    "accessibility.signals.terminalCommandFailed": {
        "sound": "off"
    },
    // Sound when a terminal command succeeds.
    "accessibility.signals.terminalCommandSucceeded": {
        "sound": "off"
    },
    // Sound when terminal output is cleared.
    "accessibility.signals.clear": {
        "sound": "off"
    },
    // Editor diagnostics and navigation cues.
    // Sound when cursor is on an error.
    "accessibility.signals.positionHasError": {
        "sound": "off"
    },
    // Sound when cursor is on a warning.
    "accessibility.signals.positionHasWarning": {
        "sound": "off"
    },
    // Sound when current line has an error.
    "accessibility.signals.lineHasError": {
        "sound": "off"
    },
    // Sound when current line has a warning.
    "accessibility.signals.lineHasWarning": {
        "sound": "off"
    },
    // Sound when current line contains folded code.
    "accessibility.signals.lineHasFoldedArea": {
        "sound": "off"
    },
    // Sound when current line contains a breakpoint.
    "accessibility.signals.lineHasBreakpoint": {
        "sound": "off"
    },
    // Sound when inline suggestion appears.
    "accessibility.signals.lineHasInlineSuggestion": {
        "sound": "off"
    },
    // Sound when next-edit suggestion is available.
    "accessibility.signals.nextEditSuggestion": {
        "sound": "off"
    },
    // Sound when no inlay hints are available.
    "accessibility.signals.noInlayHints": {
        "sound": "off"
    },
    // Build/task/notebook and diff controls.
    // Sound when a task completes successfully.
    "accessibility.signals.taskCompleted": {
        "sound": "off"
    },
    // Sound when a task fails.
    "accessibility.signals.taskFailed": {
        "sound": "off"
    },
    // Sound when notebook cell execution succeeds.
    "accessibility.signals.notebookCellCompleted": {
        "sound": "off"
    },
    // Sound when notebook cell execution fails.
    "accessibility.signals.notebookCellFailed": {
        "sound": "off"
    },
    // Sound when a diff has inserted lines.
    "accessibility.signals.diffLineInserted": {
        "sound": "off"
    },
    // Sound when a diff has deleted lines.
    "accessibility.signals.diffLineDeleted": {
        "sound": "off"
    },
    // Sound when a diff has modified lines.
    "accessibility.signals.diffLineModified": {
        "sound": "off"
    },
    // Code action, debug, and voice controls.
    // Sound when a code action menu is triggered.
    "accessibility.signals.codeActionTriggered": {
        "sound": "off"
    },
    // Sound when a code action is applied.
    "accessibility.signals.codeActionApplied": {
        "sound": "off"
    },
    // Sound when debugger hits a breakpoint/stop.
    "accessibility.signals.onDebugBreak": {
        "sound": "off"
    },
    // Sound when voice recording starts.
    "accessibility.signals.voiceRecordingStarted": {
        "sound": "off"
    },
    // Sound when voice recording stops.
    "accessibility.signals.voiceRecordingStopped": {
        "sound": "off"
    },
    // Save/format cue policy: "never", "userGesture", or "always".
    "accessibility.signals.save": {
        "sound": "never"
    },
    // Format cue policy: "never", "userGesture", or "always".
    "accessibility.signals.format": {
        "sound": "never"
    }
}