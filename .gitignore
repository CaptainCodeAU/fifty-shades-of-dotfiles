# Compiled source #
###################
*.com
*.class
*.dll
*.exe
*.o
*.so
*.pyc
__pycache__/

# Logs and databases #
######################
*.log
*.sql
*.sqlite

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
tags

# Others #
######################
.env
.env.local
.env.production
node_modules/
*.swp
.zsh_history

# Do not share your private .zshrc file
.zshrc.private

# Never commit local-only SSH overrides (private hosts, ForwardAgent, etc.)
home/.ssh/config.local

# WSL-specific ComfyUI functions (private/local configuration)
home/.zsh_wsl_comfyui_functions

# Local-only slash commands and plans
Plans/
.claude/commands/todo.md
.claude/commands/fix-authors.md

# Local-only memory
MEMORY/

# Documentation generators (local tooling, not project code)
.prompts/

# Allow canonical standalone script subsystem under home/.local
!home/.local/
!home/.local/bin/
!home/.local/bin/*
!home/.local/share/
!home/.local/share/fifty-shades-of-dotfiles/
!home/.local/share/fifty-shades-of-dotfiles/scripts/
!home/.local/share/fifty-shades-of-dotfiles/scripts/*
